{
  "mode": "alpha-inventory",
  "mcp_tools": [
    {
      "name": "wormhole.agent.register",
      "requires_auth": false,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "capabilities", "type": "array", "items": "string"},
          {"name": "model", "type": "string"},
          {"name": "name", "type": "string"},
          {"name": "owner", "type": "string"},
          {"name": "permissions", "type": "array", "items": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "repositories", "type": "array", "items": "string"},
          {"name": "role", "type": "string"},
          {"name": "roles", "type": "array", "items": "string"}
        ],
        "required": [
          "capabilities",
          "model",
          "owner",
          "permissions",
          "project_id",
          "repositories",
          "roles"
        ]
      }
    },
    {
      "name": "wormhole.agent.whoami",
      "requires_auth": true,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [],
        "required": []
      }
    },
    {
      "name": "wormhole.channel.create",
      "requires_auth": true,
      "required_permission": "channel.create",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "name", "type": "string"},
          {"name": "project_id", "type": "string"}
        ],
        "required": ["name", "project_id"]
      }
    },
    {
      "name": "wormhole.channel.list",
      "requires_auth": true,
      "required_permission": "channel.list",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "project_id", "type": "string"}
        ],
        "required": ["project_id"]
      }
    },
    {
      "name": "wormhole.channel.post",
      "requires_auth": true,
      "required_permission": "channel.post",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "channel_id", "type": "string"},
          {
            "name": "event_type",
            "type": "string",
            "enum": [
              "build.failed",
              "discovery.logged",
              "message.posted",
              "review.requested",
              "task.status_changed"
            ]
          },
          {"name": "note", "type": "string"},
          {"name": "payload", "type": "object"},
          {"name": "project_id", "type": "string"}
        ],
        "required": ["channel_id", "event_type", "payload", "project_id"]
      }
    },
    {
      "name": "wormhole.channel.subscribe",
      "requires_auth": true,
      "required_permission": "channel.subscribe",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "channel_id", "type": "string"},
          {"name": "limit", "type": "integer"},
          {"name": "offset", "type": "integer"},
          {"name": "project_id", "type": "string"}
        ],
        "required": ["channel_id", "project_id"]
      }
    },
    {
      "name": "wormhole.git.link_commit",
      "requires_auth": true,
      "required_permission": "git.link_commit",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "commit_sha", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "repo", "type": "string"},
          {"name": "summary", "type": "string"},
          {"name": "task_id", "type": "string"}
        ],
        "required": ["commit_sha", "project_id", "repo", "summary", "task_id"]
      }
    },
    {
      "name": "wormhole.git.request_review",
      "requires_auth": true,
      "required_permission": "git.request_review",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "pr_url", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "repo", "type": "string"},
          {"name": "summary", "type": "string"}
        ],
        "required": ["pr_url", "project_id", "repo", "summary"]
      }
    },
    {
      "name": "wormhole.kb.get",
      "requires_auth": true,
      "required_permission": "kb.get",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "article_id", "type": "string"},
          {"name": "project_id", "type": "string"}
        ],
        "required": ["article_id", "project_id"]
      }
    },
    {
      "name": "wormhole.kb.get_links",
      "requires_auth": true,
      "required_permission": "kb.get_links",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "article_id", "type": "string"},
          {"name": "project_id", "type": "string"}
        ],
        "required": ["article_id", "project_id"]
      }
    },
    {
      "name": "wormhole.kb.search",
      "requires_auth": true,
      "required_permission": "kb.search",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "limit", "type": "integer"},
          {"name": "project_id", "type": "string"},
          {"name": "query", "type": "string"}
        ],
        "required": ["project_id", "query"]
      }
    },
    {
      "name": "wormhole.kb.write",
      "requires_auth": true,
      "required_permission": "kb.write",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "body", "type": "string"},
          {"name": "force", "type": "boolean"},
          {"name": "frontmatter", "type": "object"},
          {"name": "links", "type": "array", "items": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "title", "type": "string"}
        ],
        "required": ["body", "force", "links", "project_id", "title"]
      }
    },
    {
      "name": "wormhole.sync.bootstrap",
      "requires_auth": true,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "namespace_id", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "version", "type": "integer"}
        ],
        "required": ["namespace_id", "project_id", "version"]
      }
    },
    {
      "name": "wormhole.sync.conflict_report",
      "requires_auth": true,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "conflict_type", "type": "string"},
          {"name": "entity_id", "type": "string"},
          {"name": "entity_type", "type": "string"},
          {"name": "local_value", "type": "string"},
          {"name": "namespace_id", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "server_value", "type": "string"},
          {"name": "version", "type": "integer"}
        ],
        "required": [
          "conflict_type",
          "entity_id",
          "entity_type",
          "local_value",
          "namespace_id",
          "project_id",
          "server_value",
          "version"
        ]
      }
    },
    {
      "name": "wormhole.sync.incremental_pull",
      "requires_auth": true,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "last_sync", "type": "string"},
          {"name": "namespace_id", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "version", "type": "integer"}
        ],
        "required": ["namespace_id", "project_id", "version"]
      }
    },
    {
      "name": "wormhole.sync.incremental_push",
      "requires_auth": true,
      "required_permission": "",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "items", "type": "array", "items": "object"},
          {"name": "namespace_id", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "version", "type": "integer"}
        ],
        "required": ["items", "namespace_id", "project_id", "version"]
      }
    },
    {
      "name": "wormhole.task.assign",
      "requires_auth": true,
      "required_permission": "task.assign",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "owner_agent_id", "type": "string"},
          {"name": "project_id", "type": "string"},
          {"name": "task_id", "type": "string"}
        ],
        "required": ["owner_agent_id", "project_id", "task_id"]
      }
    },
    {
      "name": "wormhole.task.create",
      "requires_auth": true,
      "required_permission": "task.create",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "description", "type": "string"},
          {"name": "due_by", "type": "string", "format": "date-time"},
          {"name": "parent_task_id", "type": "string"},
          {"name": "priority", "type": "integer"},
          {"name": "project_id", "type": "string"},
          {"name": "title", "type": "string"}
        ],
        "required": ["description", "priority", "project_id", "title"]
      }
    },
    {
      "name": "wormhole.task.list",
      "requires_auth": true,
      "required_permission": "task.list",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "project_id", "type": "string"},
          {"name": "role", "type": "string"},
          {"name": "status", "type": "string"}
        ],
        "required": ["project_id"]
      }
    },
    {
      "name": "wormhole.task.update_status",
      "requires_auth": true,
      "required_permission": "task.update_status",
      "input_schema": {
        "type": "object",
        "properties": [
          {"name": "channel_id", "type": "string"},
